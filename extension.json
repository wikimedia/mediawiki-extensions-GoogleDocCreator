{
	"name": "GoogleDocCreator",
	"version": "2.0",
	"author": [
		"Nischay Nahata",
		"Sanjay Thiyagarajan"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:GoogleDocCreator",
	"descriptionmsg": "googledoccreator-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "parserhook",
	"load_composer_autoloader": true,
	"MessagesDirs": {
		"GoogleDocCreator": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"GoogleDocsCreatorAlias": "GoogleDocCreator.alias.php"
	},
	"SpecialPages": {
		"GoogleDocCreator": "SpecialGoogleDocCreator"
	},
	"AutoloadClasses": {
		"SpecialGoogleDocCreator": "special/SpecialGoogleDocCreator.php"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\GoogleDocCreator\\": "includes/"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\GoogleDocCreator\\Hooks"
		}
	},
	"Hooks": {
		"ParserFirstCallInit": "main"
	},
	"config": {
		"GoogleApiClientCredentialsPath": ""
	},
	"requires": {
		"MediaWiki": ">= 1.46.0"
	},
	"manifest_version": 1
}
